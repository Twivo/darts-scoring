# Supabase connection (safe to expose: the anon key is public by design;
# Row-Level Security protects writes). Copy to .env.local and fill in.
VITE_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
VITE_SUPABASE_ANON_KEY=YOUR-ANON-PUBLIC-KEY

# When these are unset, the app falls back to local-only mode (LocalStorage),
# exactly like before — nothing breaks.
